+    def _get_topic_partition_count(self, topic_name: str) -> Optional[int]:
+        """Get current partition count for a topic."""
+        if not self.admin_client:
+            raise TopicInitializationError("Admin client not initialized")
+
+        try:
+            metadata = self.admin_client.describe_topics(topics=[topic_name])
+            topic_meta = None
+
+            if isinstance(metadata, list) and metadata:
+                topic_meta = metadata[0]
+            elif isinstance(metadata, dict):
+                topic_meta = metadata.get(topic_name)
+
+            if not topic_meta:
+                logger.warning("No metadata found for topic '%s'", topic_name)
+                return None
+
+            partitions = topic_meta.get("partitions", [])
+            return len(partitions)
+        except Exception as e:
+            logger.error("Failed to get partition count for topic '%s': %s", topic_name, e)
+            return None
+
+    def _ensure_min_partitions(self, topic_name: str, min_partitions: int) -> bool:
+        """Ensure a topic has at least the requested partition count."""
+        if not self.admin_client:
+            raise TopicInitializationError("Admin client not initialized")
+
+        current_partitions = self._get_topic_partition_count(topic_name)
+        if current_partitions is None:
+            return False
+
+        if current_partitions >= min_partitions:
+            logger.info(
+                "Topic '%s' partition config OK: current=%s required=%s",
+                topic_name,
+                current_partitions,
+                min_partitions,
+            )
+            return True
+
+        try:
+            fs = self.admin_client.create_partitions(
+                {topic_name: NewPartitions(total_count=min_partitions)},
+                validate_only=False,
+            )
+            for topic, future in fs.items():
+                future.result(timeout=10)
+                logger.info(
+                    "Increased partitions for topic '%s' from %s to %s",
+                    topic,
+                    current_partitions,
+                    min_partitions,
+                )
+            return True
+        except Exception as e:
+            logger.error("Failed to increase partitions for topic '%s': %s", topic_name, e)
+            return False
+
